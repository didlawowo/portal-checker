# Patterns to ignore when building Helm packages.
# Default Helm patterns:
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# Project-specific: exclude development-only values overrides
values/

# Never package local TLS material (real certs are mounted at runtime)
certs/
*.crt
*.pem
*.key
